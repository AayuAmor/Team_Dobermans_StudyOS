# ── Whisper ───────────────────────────────────────────────────────────────────
# Available models (larger = more accurate, slower, more RAM):
#   tiny | base | small | medium | large
WHISPER_MODEL=base

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.
# Use ["*"] to allow all (development only).
# For Android emulator: ["http://10.0.2.2:8000"]
CORS_ORIGINS=["*"]
