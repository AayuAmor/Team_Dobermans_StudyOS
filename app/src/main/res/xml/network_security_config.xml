<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (HTTP) is allowed only for local development hosts:
    • 10.0.2.2      — Android Emulator → host machine localhost
    • 10.0.3.2      — Genymotion → host machine localhost
    • localhost / 127.0.0.1 — loopback (device shell, instrumented tests)
    • 192.168.0.0/16 — LAN subnet for real-device → development laptop

  All other traffic (production, Firebase, Google APIs) must use HTTPS.
  Remove or restrict these domains before a production release.
-->
<network-security-config>

    <!-- Development: allow HTTP to local backend hosts -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- LAN — covers 192.168.x.x for real-device testing -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="true">192.168.1.143</domain>
    </domain-config>

    <!-- Default: all other traffic requires TLS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
